{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "deck",
  "type": "object",
  "required": ["slug", "title", "tone", "slides"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 4 },
    "subtitle": { "type": "string" },
    "tone": { "type": "string", "enum": ["pitch", "doc"] },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "slides": {
      "type": "array",
      "minItems": 4,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["title", "bullets"],
        "properties": {
          "title": { "type": "string", "minLength": 3 },
          "bullets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": { "type": "string", "minLength": 4 }
          },
          "quote": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": { "type": "string" },
              "author": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
